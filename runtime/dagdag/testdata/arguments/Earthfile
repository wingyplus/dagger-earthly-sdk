VERSION 0.8

args:
  ARG NAME
  ARG --required TAG
  ARG ARG_DEFAULT="default value"

# Documented argument target.
documented-args:
  # The image name.
  ARG IMAGE_NAME

# Mix of builtin and user ARGs — builtins must not appear as Dagger params.
builtin-args:
  ARG TARGETPLATFORM
  ARG EARTHLY_CI
  ARG USER_ARG
